{
  "routes": [
    { "src": "^/app$", "dest": "/index.html" },
    { "src": "^/$", "has": [{"type": "query", "key": "type", "value": "recovery"}], "dest": "/reset-password.html" },
    { "src": "^/$", "dest": "/landing.html" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
